# Rename this file to .env and fill in real values before running the app.

# Flask secret key - used to sign session cookies. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# Master encryption key for file encryption - used to encrypt/decrypt per-file keys.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=change-this-to-a-generated-fernet-key

# Database URL - leave unset to use the default local SQLite database
# (an absolute path is used automatically so it works from any working directory).
# Only set this if you want to point at a different database, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/securecloud
# DATABASE_URL=

# Max upload size in MB
MAX_UPLOAD_MB=25
